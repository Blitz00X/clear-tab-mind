{
  "manifest_version": 3,
  "name": "Clear Tab Mind",
  "version": "2.0.0",
  "description": "Scalable tab & content management with workspaces, RSS, hibernation, and media hub",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "tabGroups",
    "contextMenus",
    "notifications",
    "sidePanel",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "Clear Tab Mind"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Open Clear Tab Mind side panel"
    }
  }
}